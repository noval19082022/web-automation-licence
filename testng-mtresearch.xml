<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="MT Research Login Test Suite" parallel="tests" thread-count="3">

    <test name="Tenant Login Research">
        <parameter name="squadName" value="MTResearch/Tenant"/>
        <classes>
            <class name="runners.MTResearchTenantTestRunner"/>
        </classes>
    </test>

    <test name="Owner Login Research">
        <parameter name="squadName" value="MTResearch/Owner"/>
        <classes>
            <class name="runners.MTResearchOwnerTestRunner"/>
        </classes>
    </test>

    <test name="Admin Login Research">
        <parameter name="squadName" value="MTResearch/Admin"/>
        <classes>
            <class name="runners.MTResearchAdminTestRunner"/>
        </classes>
    </test>

</suite>
